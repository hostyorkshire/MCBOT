# -----------------------------------------------------------------------
# MeshCore CYOA Bot – environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# -----------------------------------------------------------------------

# Groq API key – get a free key at https://console.groq.com
# To rotate: update this value and run: sudo systemctl restart mcbot
# Never paste your key into chat logs or commit it to version control.
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use.
# llama3-8b-8192 was decommissioned – use a current model instead.
# Current free-tier options (check https://console.groq.com/docs/models):
#   llama-3.1-8b-instant    (fast, lightweight – recommended default)
#   llama-3.3-70b-versatile (higher quality, slower)
#   gemma2-9b-it
#   mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# USB serial port for the MeshCore LoRa radio
# Linux examples: /dev/ttyUSB0, /dev/ttyACM0
# macOS example:  /dev/cu.usbserial-0001
SERIAL_PORT=/dev/ttyUSB0

# Serial baud rate (must match the MeshCore firmware configuration)
BAUD_RATE=115200

# Maximum characters per LoRa message chunk.
# MeshCore supports up to ~220 bytes of payload per packet.
MAX_CHUNK_SIZE=200

# Seconds to wait between consecutive message chunks (avoids flooding)
CHUNK_DELAY=2.0

# Maximum number of conversation turns to keep per user session.
# Lower values reduce RAM usage on the Raspberry Pi Zero 2W.
MAX_HISTORY=10

# Number of send attempts per chunk before giving up (must be ≥ 1).
SEND_RETRIES=3

# Base delay in seconds for the first retry backoff (doubles each attempt).
SEND_RETRY_BASE_DELAY=0.5

# Maximum delay in seconds between retries (caps the exponential growth).
SEND_RETRY_MAX_DELAY=3.0

# (Optional) Restrict /chat CORS to a specific origin domain.
# When set, only requests from this origin are allowed cross-origin access
# to the /chat endpoint.  Defaults to "*" (any origin) when unset.
# Example: CHAT_CORS_ORIGIN=https://www.yourdomain.com
# CHAT_CORS_ORIGIN=*
